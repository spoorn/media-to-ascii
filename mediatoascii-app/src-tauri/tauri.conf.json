{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "media-to-ascii",
  "version": "0.1.0",
  "identifier": "com.mediatoascii-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "media-to-ascii",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "minWidth": 600,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/spoornowlicon2.ico",
      "icons/spoornowlicon2.png"
    ]
  }
}
